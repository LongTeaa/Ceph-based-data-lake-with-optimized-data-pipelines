# Runtime profile
APP_ENV=local
PROJECT_NAME=ceph-data-lake

# S3-compatible object storage.
# Local Phase 1 uses MinIO on localhost:19000. For Ceph RGW, change endpoint to
# your RGW URL, for example http://localhost:7480 or http://<rgw-host>:7480.
S3_ENDPOINT=http://localhost:19000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1
S3_PATH_STYLE_ACCESS=true
S3_USE_SSL=false

# Data Lake buckets
BRONZE_BUCKET=datalake-bronze
SILVER_BUCKET=datalake-silver
GOLD_BUCKET=datalake-gold
SYSTEM_BUCKET=datalake-system

# Local source data
NYC_TAXI_SOURCE_DIR=data/source/nyc-taxi
IMAGE_SOURCE_DIR=data/source/images

# Spark
SPARK_MASTER_URL=spark://localhost:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SQL_SHUFFLE_PARTITIONS=8
SPARK_JARS_PACKAGES=org.apache.hadoop:hadoop-aws:3.3.4
SPARK_IVY_DIR=.spark-ivy
SPARK_LOCAL_DIR=.spark-tmp
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# Airflow
AIRFLOW_UID=50000
AIRFLOW_HOME=/opt/airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_WEBSERVER_SECRET_KEY=local-dev-secret-key
DATA_LAKE_PROJECT_ROOT=/opt/airflow/project
DATA_LAKE_PYTHON_BIN=python
DATA_LAKE_SPARK_SUBMIT_BIN=spark-submit

# Benchmark
BENCHMARK_RUN_ID=local-baseline
BENCHMARK_OUTPUT_DIR=results

# Pinned image versions for later phases. Do not use latest.
POSTGRES_IMAGE=postgres:16.3
REDIS_IMAGE=redis:7.2.5
AIRFLOW_IMAGE=ceph-data-lake-airflow:2.9.3-python3.11
SPARK_IMAGE=ceph-data-lake-spark:3.5.1
TRINO_IMAGE=trinodb/trino:455
PROMETHEUS_IMAGE=prom/prometheus:v2.53.1
GRAFANA_IMAGE=grafana/grafana:11.1.0
MINIO_IMAGE=minio/minio:RELEASE.2024-07-16T23-46-41Z
